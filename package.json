{
	"name": "@involvex/flux",
	"version": "0.1.0",
	"description": "Next-generation hybrid mobile development framework combining Expo and Ionic",
	"keywords": [
		"expo",
		"ionic",
		"react-native",
		"mobile",
		"hybrid",
		"cross-platform",
		"framework"
	],
	"license": "MIT",
	"author": "flux Team",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./ui": "./src/ui/index.ts",
		"./navigation": "./src/navigation/index.ts",
		"./config": "./src/config/index.ts",
		"./build": "./src/build/index.ts",
		"./dev": "./src/dev/index.ts",
		"./plugins": "./src/plugins/index.ts",
		"./android": "./src/android/index.ts",
		"./web": "./src/web/index.ts",
		"./updates": "./src/updates/index.ts"
	},
	"module": "src/index.ts",
	"bin": {
		"flux": "./dist/index.js"
	},
	"scripts": {
		"prebuild": "bun run format && bun run lint && bun run typecheck",
		"build": "bun build src/index.ts --outdir dist --target node",
		"dev": "bun run src/index.ts",
		"format": "prettier . --write",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:e2e": "bun test tests/e2e",
		"test:unit": "bun test tests/unit",
		"typecheck": "bunx tsc --noEmit"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@capacitor/core": "^6.0.0",
		"@expo/config-plugins": "^7.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"chalk": "^5.3.0",
		"commander": "^11.1.0",
		"node-fetch": "^3.3.2",
		"ora": "^8.0.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-native": "^0.73.0",
		"react-router-dom": "^7.15.0",
		"vite": "^8.0.10"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@involvex/prettier-config": "^0.0.5",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/node": "^20.10.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-native": "^0.72.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"jiti": "^2.7.0",
		"prettier": "^3.8.3",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"engines": {
		"bun": ">=1.0.0",
		"node": ">=18.0.0"
	}
}
