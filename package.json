{
	"name": "flux",
	"version": "0.1.0",
	"description": "Next-generation hybrid mobile development framework combining Expo and Ionic",
	"keywords": [
		"expo",
		"ionic",
		"react-native",
		"mobile",
		"hybrid",
		"cross-platform",
		"framework"
	],
	"license": "MIT",
	"author": "flux Team",
	"type": "module",
	"module": "src/index.ts",
	"bin": {
		"flux": "./dist/cli.js"
	},
	"scripts": {
		"prebuild": "bun run format && bun run lint && bun run typecheck",
		"build": "bun build src/index.ts --outdir dist --target node",
		"dev": "bun run src/index.ts",
		"format": "prettier . --write",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@capacitor/core": "^6.0.0",
		"@expo/config-plugins": "^7.0.0",
		"chalk": "^5.3.0",
		"commander": "^11.1.0",
		"ora": "^8.0.0",
		"react": "^18.2.0",
		"react-native": "^0.73.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@involvex/prettier-config": "^0.0.5",
		"@types/bun": "latest",
		"@types/node": "^20.10.0",
		"@types/react": "^18.2.0",
		"@types/react-native": "^0.72.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"jiti": "^2.7.0",
		"prettier": "^3.8.3",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"engines": {
		"bun": ">=1.0.0",
		"node": ">=18.0.0"
	}
}
